cat > .gitignore << 'EOF'
# Virtual environment
venv/

# Data files (large / regeneratable)
data/raw/*.parquet
data/raw/*.csv
data/processed/*.h5
data/processed/*.npy
data/processed/*.csv

# Results (plots and reports — regeneratable)
src/clustering/*/results/
src/evaluation/results/
src/clustering/results/

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/
EOF
